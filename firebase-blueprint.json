{
  "entities": {
    "Pet": {
      "title": "Pet",
      "description": "A pet available for purchase",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "slug": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["dog", "cat", "bird", "fish", "rabbit", "exotic"] },
        "breed": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["available", "sold"] },
        "age": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Unknown"] },
        "color": { "type": "string" },
        "weight": { "type": "string" },
        "temperament": { "type": "string" },
        "vaccinationStatus": { "type": "string" },
        "healthStatus": { "type": "string" },
        "origin": { "type": "string" },
        "microchipId": { "type": "string" },
        "lifeExpectancy": { "type": "string" },
        "energyLevel": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "sheddingLevel": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "groomingNeeds": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "socialNeeds": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "price", "status"]
    },
    "Product": {
      "title": "Product",
      "description": "Pet food or accessory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Food", "Accessories", "Grooming", "Health", "Toys", "Beds", "Other"] },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "discountLabel": { "type": "string", "description": "e.g. 'Sale', 'Limited'" },
        "productCoupons": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "discount": { "type": "number" },
              "type": { "type": "string", "enum": ["percentage", "fixed"] }
            }
          }
        },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "number" },
        "variations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "price": { "type": "number" },
              "stock": { "type": "number" }
            }
          }
        },
        "specifications": { "type": "string" },
        "ingredients": { "type": "string" },
        "usageInstructions": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer purchase order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped", "delivered"] },
        "razorpayOrderId": { "type": "string" },
        "razorpayPaymentId": { "type": "string" },
        "couponCode": { "type": "string", "description": "Applied coupon code" },
        "discountAmount": { "type": "number", "description": "Total discount applied" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "amount", "status"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Universal discount coupon",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["percentage", "fixed"] },
        "value": { "type": "number" },
        "minOrderValue": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" },
        "usageCount": { "type": "number" },
        "maxUsage": { "type": "number" }
      },
      "required": ["code", "type", "value", "isActive"]
    },
    "ShopSettings": {
      "title": "Shop Settings",
      "description": "Global configuration for the shop",
      "type": "object",
      "properties": {
        "deliveryFeeThreshold": { "type": "number", "description": "Free delivery threshold" },
        "fixedDeliveryFee": { "type": "number", "description": "Fixed delivery fee" }
      },
      "required": ["deliveryFeeThreshold", "fixedDeliveryFee"]
    }
  },
  "firestore": {
    "/pets": {
      "schema": "Pet",
      "description": "Collection of available pets"
    },
    "/products": {
      "schema": "Product",
      "description": "Collection of pet accessories and food"
    },
    "/orders": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "/coupons": {
      "schema": "Coupon",
      "description": "Collection of universal discount coupons"
    },
    "/settings": {
      "schema": "ShopSettings",
      "description": "Global shop settings"
    }
  }
}
